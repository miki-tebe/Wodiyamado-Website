---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import HeroSection from "@/components/HeroSection";
import FeaturedEvents from "@/components/events/FeaturedEvents";
import StructurePreview from "@/components/StructurePreview";
import LatestBlogs from "@/components/LatestBlogs";
import { getPublicEvents } from "@/lib/events-store";
import { getCmsBlogs, getCmsGallery, getCmsSiteStats } from "@/lib/emdash-content";

const openModal = Astro.url.searchParams.get("modal") == "true" ? true : false;

const events = await getPublicEvents();

const recentEvents = events.slice(0, 3);
const recentBlogs = await getCmsBlogs(3);
const gallery = await getCmsGallery();
const stats = await getCmsSiteStats();
---

<Layout
  title="Welcome to Rotaract Club of Wodiyamado"
  description="We are a group of young leaders dedicated to improving our communities through service."
>
  <main class="flex-1">
    <HeroSection gallery={gallery} stats={stats} openModal={openModal} client:load />
    <FeaturedEvents events={recentEvents} client:load />
    <LatestBlogs blogs={recentBlogs} client:load />
    <StructurePreview client:load />
  </main>
</Layout>
