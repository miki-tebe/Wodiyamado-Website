{
  "name": "wodiyamado_website",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "npm@10.9.3",
  "scripts": {
    "dev": "npm run setup:emdash && npm run build:css && astro dev",
    "start": "npm run dev",
    "build": "npm run setup:emdash && npm run build:css && astro check && astro build",
    "build:css": "tailwindcss -i ./src/styles/globals.css -o ./src/styles/generated.css",
    "import:content": "npm run setup:emdash && node scripts/import-content-to-emdash.mjs",
    "backfill:post-dates": "npm run setup:emdash && node scripts/backfill-post-dates.mjs",
    "seed:site-content": "npm run setup:emdash && node scripts/seed-site-content.mjs",
    "setup:emdash": "node -e \"fs.mkdirSync('./data',{recursive:true});fs.mkdirSync('./uploads',{recursive:true})\"",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdoc": "^1.0.4",
    "@astrojs/react": "^5.0.4",
    "@astrojs/vercel": "^10.0.6",
    "@hookform/resolvers": "^3.9.0",
    "@libsql/client": "^0.15.2",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@react-email/components": "0.5.1",
    "@tiptap/extension-collaboration": "^3.22.5",
    "@tiptap/y-tiptap": "^3.0.3",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vercel/analytics": "^1.3.1",
    "@vercel/speed-insights": "^1.2.0",
    "astro": "^6.3.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "embla-carousel-autoplay": "^8.3.0",
    "embla-carousel-react": "^8.0.0",
    "emdash": "^0.10.0",
    "framer-motion": "^12.23.12",
    "lucide-astro": "^0.396.0",
    "lucide-react": "^0.315.0",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-email": "4.2.8",
    "react-hook-form": "^7.53.0",
    "resend": "^4.1.2",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss": "^3.4.11",
    "tailwindcss-animate": "^1.0.7",
    "tsparticles": "^3.9.1",
    "typescript": "^6.0.3",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^4.4.3"
  },
